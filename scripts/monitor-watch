#!/bin/sh

SETUPWM=~/Programming/Projects/dotfiles/scripts/setupwm

# Start waybar with the right config based on current monitor count
monitor_count=$(hyprctl monitors -j | grep -c '"id"')
if [ "$monitor_count" -gt 1 ]; then
    $SETUPWM multiple
else
    $SETUPWM single
fi

# Listen to Hyprland socket events and auto-configure monitors
handle() {
    case $1 in
        monitoradded*)
            $SETUPWM multiple
            ;;
        monitorremoved*)
            $SETUPWM single
            ;;
    esac
}

socat - "UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" | while read -r line; do
    handle "$line"
done